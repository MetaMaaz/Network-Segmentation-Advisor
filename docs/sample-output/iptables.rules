#!/usr/bin/env bash
# Generated by segmentation-advisor — review before applying.
# Inter-zone policy enforced on the FORWARD chain of a zone router.
set -euo pipefail

# Flush and default-deny: zero-trust posture (NIST SP 800-207 §3.1.2).
iptables -F FORWARD
iptables -P FORWARD DROP

# Allow return traffic for established sessions.
iptables -A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

# user-vlan -> dmz: Users may reach published web services only; NIST SP 800-207 §2.1 Tenet 3 — access granted per-session with least privilege
iptables -A FORWARD -s 10.10.40.0/24 -d 10.10.10.0/24 -p tcp --dport 80 -m conntrack --ctstate NEW -j ACCEPT

# user-vlan -> dmz: Users may reach published web services only; NIST SP 800-207 §2.1 Tenet 3 — access granted per-session with least privilege
iptables -A FORWARD -s 10.10.40.0/24 -d 10.10.10.0/24 -p tcp --dport 443 -m conntrack --ctstate NEW -j ACCEPT

# dmz -> app-tier: Web tier may call internal app APIs on observed ports only; PCI DSS v4.0 Req 1.2/1.3 — restrict traffic to that which is necessary
iptables -A FORWARD -s 10.10.10.0/24 -d 10.10.20.0/24 -p tcp --dport 8080 -m conntrack --ctstate NEW -j ACCEPT

# user-vlan -> app-tier: Users may reach internal applications on observed ports; NIST SP 800-207 §2.1 Tenet 3 — access granted per-session with least privilege
iptables -A FORWARD -s 10.10.40.0/24 -d 10.10.20.0/24 -p tcp --dport 8080 -m conntrack --ctstate NEW -j ACCEPT

# app-tier -> data-tier: Only the application tier may query databases, on observed DB ports; PCI DSS v4.0 scoping guidance — segmentation isolates the cardholder/sensitive data environment and reduces audit scope
iptables -A FORWARD -s 10.10.20.0/24 -d 10.10.30.0/24 -p tcp --dport 3306 -m conntrack --ctstate NEW -j ACCEPT

# app-tier -> data-tier: Only the application tier may query databases, on observed DB ports; PCI DSS v4.0 scoping guidance — segmentation isolates the cardholder/sensitive data environment and reduces audit scope
iptables -A FORWARD -s 10.10.20.0/24 -d 10.10.30.0/24 -p tcp --dport 5432 -m conntrack --ctstate NEW -j ACCEPT

# user-vlan -> management: Domain clients need DNS/Kerberos/LDAP from domain controllers; SMB (445) deliberately excluded — NIST SP 800-207 §2.1 Tenet 4 — no implicit trust from network location
iptables -A FORWARD -s 10.10.40.0/24 -d 10.10.60.0/24 -p tcp --dport 53 -m conntrack --ctstate NEW -j ACCEPT

# user-vlan -> management: Domain clients need DNS/Kerberos/LDAP from domain controllers; SMB (445) deliberately excluded — NIST SP 800-207 §2.1 Tenet 4 — no implicit trust from network location
iptables -A FORWARD -s 10.10.40.0/24 -d 10.10.60.0/24 -p tcp --dport 88 -m conntrack --ctstate NEW -j ACCEPT

# user-vlan -> management: Domain clients need DNS/Kerberos/LDAP from domain controllers; SMB (445) deliberately excluded — NIST SP 800-207 §2.1 Tenet 4 — no implicit trust from network location
iptables -A FORWARD -s 10.10.40.0/24 -d 10.10.60.0/24 -p tcp --dport 389 -m conntrack --ctstate NEW -j ACCEPT

# user-vlan -> management: Domain clients need DNS/Kerberos/LDAP from domain controllers; SMB (445) deliberately excluded — NIST SP 800-207 §2.1 Tenet 4 — no implicit trust from network location
iptables -A FORWARD -s 10.10.40.0/24 -d 10.10.60.0/24 -p tcp --dport 636 -m conntrack --ctstate NEW -j ACCEPT

# app-tier -> management: Domain clients need DNS/Kerberos/LDAP from domain controllers; SMB (445) deliberately excluded — NIST SP 800-207 §2.1 Tenet 4 — no implicit trust from network location
iptables -A FORWARD -s 10.10.20.0/24 -d 10.10.60.0/24 -p tcp --dport 53 -m conntrack --ctstate NEW -j ACCEPT

# app-tier -> management: Domain clients need DNS/Kerberos/LDAP from domain controllers; SMB (445) deliberately excluded — NIST SP 800-207 §2.1 Tenet 4 — no implicit trust from network location
iptables -A FORWARD -s 10.10.20.0/24 -d 10.10.60.0/24 -p tcp --dport 88 -m conntrack --ctstate NEW -j ACCEPT

# app-tier -> management: Domain clients need DNS/Kerberos/LDAP from domain controllers; SMB (445) deliberately excluded — NIST SP 800-207 §2.1 Tenet 4 — no implicit trust from network location
iptables -A FORWARD -s 10.10.20.0/24 -d 10.10.60.0/24 -p tcp --dport 389 -m conntrack --ctstate NEW -j ACCEPT

# app-tier -> management: Domain clients need DNS/Kerberos/LDAP from domain controllers; SMB (445) deliberately excluded — NIST SP 800-207 §2.1 Tenet 4 — no implicit trust from network location
iptables -A FORWARD -s 10.10.20.0/24 -d 10.10.60.0/24 -p tcp --dport 636 -m conntrack --ctstate NEW -j ACCEPT

# user-vlan -> iot-vlan: Workstations may print, nothing more; IoT stays isolated — NIST SP 800-207 §3.1.2 — network micro-segmentation
iptables -A FORWARD -s 10.10.40.0/24 -d 10.10.50.0/24 -p tcp --dport 631 -m conntrack --ctstate NEW -j ACCEPT

# user-vlan -> iot-vlan: Workstations may print, nothing more; IoT stays isolated — NIST SP 800-207 §3.1.2 — network micro-segmentation
iptables -A FORWARD -s 10.10.40.0/24 -d 10.10.50.0/24 -p tcp --dport 9100 -m conntrack --ctstate NEW -j ACCEPT

# management -> dmz: Administrative access (SSH/RDP) originates only from the management zone via the jump host; NIST SP 800-207 §2.1 Tenet 3 — access granted per-session with least privilege
iptables -A FORWARD -s 10.10.60.0/24 -d 10.10.10.0/24 -p tcp --dport 22 -m conntrack --ctstate NEW -j ACCEPT

# management -> app-tier: Administrative access (SSH/RDP) originates only from the management zone via the jump host; NIST SP 800-207 §2.1 Tenet 3 — access granted per-session with least privilege
iptables -A FORWARD -s 10.10.60.0/24 -d 10.10.20.0/24 -p tcp --dport 22 -m conntrack --ctstate NEW -j ACCEPT

# management -> data-tier: Administrative access (SSH/RDP) originates only from the management zone via the jump host; NIST SP 800-207 §2.1 Tenet 3 — access granted per-session with least privilege
iptables -A FORWARD -s 10.10.60.0/24 -d 10.10.30.0/24 -p tcp --dport 22 -m conntrack --ctstate NEW -j ACCEPT

# management -> user-vlan: Administrative access (SSH/RDP) originates only from the management zone via the jump host; NIST SP 800-207 §2.1 Tenet 3 — access granted per-session with least privilege
iptables -A FORWARD -s 10.10.60.0/24 -d 10.10.40.0/24 -p tcp --dport 3389 -m conntrack --ctstate NEW -j ACCEPT

# Everything else falls through to the DROP policy.
